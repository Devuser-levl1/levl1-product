generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  website     String?
  voiceAccent String   @default("american")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // plan: trial | starter | professional | enterprise | expired
  plan              String    @default("trial")
  trialStartedAt    DateTime  @default(now())
  trialExpiresAt    DateTime?
  trialInterviews   Int       @default(0)
  trialLimit        Int       @default(5)

  // Paid subscription
  subscriptionId     String?
  subscriptionStatus String?
  currentPeriodEnd   DateTime?

  // Usage
  interviewsUsed  Int @default(0)
  interviewsLimit Int @default(5)

  // Billing
  billingEmail       String?
  cashfreeCustomerId String?

  // Email / sender config
  senderName           String?
  senderEmail          String?
  resendDomainId       String?
  resendDomainVerified Boolean @default(false)

  // White-label
  logoUrl    String?
  brandColor String? @default("#4F46E5")

  // Business / GST details
  legalName      String?
  gstNumber      String?
  panNumber      String?
  foundedYear    Int?
  teamSize       String?
  primaryService String?

  // Registered address
  registeredAddress String?
  city              String?
  state             String?
  pinCode           String?

  // Onboarding
  onboardingComplete Boolean @default(false)
  onboardingStep     Int     @default(1)

  positions     Position[]
  users         User[]
  subscriptions Subscription[]
  notifications Notification[]
  teamMembers   TeamMember[]
  clients       Client[]
  interviewsApiKeys         InterviewsApiKey[]
  interviewsWebhookEndpoints InterviewsWebhookEndpoint[]
  atsConnections            AtsConnection[]
}

// ── Levl1 SSO: unified identity + entitlements (Phase 4) ───────────────────
// Links a customer's Hire identity and Interviews identity (same email) and
// records what they're entitled to. One Levl1 account → both products when
// entitled.
model LevlAccount {
  id               String   @id @default(cuid())
  email            String   @unique
  // Hire side
  hireUserId       String?  @unique
  hireTenantId     String?
  // Interviews side
  interviewsUserId String?  @unique
  agencyId         String?
  // Entitlements (what they've bought / opted into)
  entHire          Boolean  @default(false)
  entInterviews    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ── ATS connector framework (Phase 3) ──────────────────────────────────────
// Lets an Interviews customer connect an external ATS (or Levl1 Hire) and FETCH
// jobs + candidates into Interviews to screen. Tied to Agency.
model AtsConnection {
  id           String   @id @default(cuid())
  agencyId     String
  agency       Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  provider     String   // levl1_hire | greenhouse | lever | salesforce
  status       String   @default("connected") // connected | error | disconnected
  authType     String   // oauth | api_key
  credentials  String?  // AES-256-GCM encrypted creds/tokens (never plaintext)
  config       Json?    // non-secret config (resolved ids, cursors, options)
  lastSyncedAt DateTime?
  lastError    String?
  createdAt    DateTime @default(now())
  syncedRecords AtsSyncedRecord[]
  @@unique([agencyId, provider])
}

// Idempotency map: external record id → imported Interviews id, per connection.
model AtsSyncedRecord {
  id           String   @id @default(cuid())
  connectionId String
  connection   AtsConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  kind         String   // job | candidate
  externalId   String
  internalId   String   // Position.id (job) or Candidate.id (candidate)
  syncedAt     DateTime @default(now())
  @@unique([connectionId, kind, externalId])
  @@index([connectionId])
}

// ── Interviews-owned public-API integration models (Phase 1) ────────────────
// The standalone Interviews product's own API keys + webhooks, keyed to Agency
// (the Interviews tenant). Mirrors the Hire-side ApiKey/WebhookEndpoint shape so
// external ATSs integrate with Interviews directly — no Hire dependency.
model InterviewsApiKey {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name        String
  prefix      String
  hashedKey   String   @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  @@index([agencyId])
}

model InterviewsWebhookEndpoint {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  url         String
  secret      String
  events      String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([agencyId])
}

model InterviewsWebhookDelivery {
  id          String   @id @default(cuid())
  endpointId  String
  event       String
  payload     Json
  status      String   @default("pending") // pending | success | failed
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  @@index([endpointId])
}

model TeamMember {
  id          String    @id @default(cuid())
  agencyId    String
  agency      Agency    @relation(fields: [agencyId], references: [id])
  name        String
  email       String
  role        String    @default("recruiter") // admin | recruiter | viewer
  status      String    @default("invited")   // invited | active
  inviteToken String?   @unique
  joinedAt    DateTime?
  createdAt   DateTime  @default(now())
}

model Client {
  id           String     @id @default(cuid())
  agencyId     String
  agency       Agency     @relation(fields: [agencyId], references: [id])
  name         String
  industry     String?
  website      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  managerEmail String?
  l2Threshold  Int        @default(75)
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  positions    Position[]
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  phone              String?
  role               String    @default("recruiter")
  agencyId           String
  agency             Agency    @relation(fields: [agencyId], references: [id])
  passwordHash       String?
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  lastLoginAt         DateTime?
  createdAt          DateTime  @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  agencyId           String
  agency             Agency    @relation(fields: [agencyId], references: [id])
  plan               String
  status             String
  cashfreeSubId      String?
  amount             Int
  currency           String    @default("INR")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
}

model Position {
  id                 String    @id @default(cuid())
  title              String
  company            String
  department         String?
  roleType           String    @default("IC")
  experienceLevel    String
  primaryDomain      String?
  techStack          String[]
  goodToHave         String[]
  domainContext      String?
  companyStage       String?
  workMode           String    @default("hybrid")
  interviewDuration  Int       @default(30)
  status             String    @default("draft")
  jdText             String?   @db.Text
  jdSource           String?   // pasted | generated | uploaded
  jdApprovedBy       String?
  jdApprovedAt       DateTime?
  techLeadApproved   Boolean   @default(false)
  hrApproved         Boolean   @default(false)
  techLeadEmail      String?
  hrEmail            String?
  clientManagerEmail String?
  l2ScoreThreshold   Int       @default(75)
  rubricApproved     Boolean   @default(false)
  scoringRubric      Json?
  dynamicIntensity   String    @default("standard")
  voiceAccent        String?
  softSkillWeightage Json?
  agencyId           String?
  agency             Agency?   @relation(fields: [agencyId], references: [id])
  clientId           String?
  client             Client?   @relation(fields: [clientId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  candidates     Candidate[]
  questionSet    QuestionSet?
  interviews     Interview[]
  positionReport PositionReport?
  interviewSlots InterviewSlot[]
  approvalTokens ApprovalToken[]
}

model ApprovalToken {
  id         String    @id @default(cuid())
  token      String    @unique @default(uuid())
  positionId String
  position   Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  type       String    // tech_lead | hr | client_jd | client_rubric
  email      String
  name       String?
  status     String    @default("pending") // pending | approved | changes_requested
  comments   String?
  approvedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
}

model QuestionSet {
  id                  String   @id @default(cuid())
  positionId          String   @unique
  position            Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  technicalQuestions  Json
  scenarioQuestions   Json
  behavioralQuestions Json
  eqQuestions         Json
  whiteboardQuestions Json
  timeAllocation      Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Candidate {
  id               String    @id @default(cuid())
  name             String
  email            String
  phone            String?
  linkedIn         String?
  currentTitle     String?
  currentCompany   String?
  totalYears       Int?
  topSkills        String[]
  educationSummary String?
  resumeText       String?   @db.Text
  positionId       String
  position         Position  @relation(fields: [positionId], references: [id])
  status           String    @default("pending")
  invitedAt        DateTime?
  scheduledAt      DateTime?
  interviewedAt    DateTime?
  score            Int?
  recommendation   String?
  uploadedAt       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  interview Interview?
  report    Report?
}

model Interview {
  id                String    @id @default(cuid())
  candidateId       String    @unique
  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  positionId        String
  position          Position  @relation(fields: [positionId], references: [id])
  status            String    @default("scheduled")
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int       @default(30)
  actualDuration    Int?
  agentOnline       Boolean   @default(false)
  candidateJoined   Boolean   @default(false)
  transcript        Json?
  questionResponses Json?
  codeEditorContent String?   @db.Text
  whiteboardUrl     String?
  runningScore      Int?
  consentGiven      Boolean   @default(false)
  consentGivenAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  token        InterviewToken?
  verification InterviewVerification?
}

model InterviewVerification {
  id              String    @id @default(cuid())
  interviewId     String    @unique
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  otpCode         String?
  otpExpiresAt    DateTime?
  otpVerifiedAt   DateTime?
  photoUrl        String?   @db.Text
  photoCapturedAt DateTime?
  nameConfirmed   String?
  nameConfirmedAt DateTime?
  tabSwitchCount  Int       @default(0)
  faceMissingMs   Int       @default(0)
  multipleFaces   Boolean   @default(false)
  integrityScore  Int       @default(100)
  integrityFlags  Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model InterviewToken {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Report {
  id                     String    @id @default(cuid())
  candidateId            String    @unique
  candidate              Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  overallScore           Int
  recommendation         String
  professionalSummary    String    @db.Text
  sectionScores          Json
  strengthAreas          Json
  concernAreas           Json
  questionWiseEvaluation Json
  transcriptHighlights   Json
  hrNote                 String    @db.Text
  l2Recommendation       String    @db.Text
  generatedAt            DateTime  @default(now())
}

model PositionReport {
  id                   String   @id @default(cuid())
  positionId           String   @unique
  position             Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  poolStrengths        Json
  poolGaps             Json
  marketObservation    String   @db.Text
  questionHealthFlags  Json
  hiringRecommendation String   @db.Text
  generatedAt          DateTime @default(now())
}

model DeletionLog {
  id         String   @id @default(cuid())
  entityType String   // candidate | interview | position
  entityId   String
  entityName String
  deletedBy  String
  reason     String   @db.Text
  agencyId   String
  createdAt  DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  page      String
  userId    String?
  createdAt DateTime @default(now())
}

model SupportTicket {
  id           String   @id @default(cuid())
  ticketNumber Int      @default(autoincrement())
  issueType    String
  subject      String
  description  String   @db.Text
  userEmail    String
  status       String   @default("open")
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model InterviewSlot {
  id          String   @id @default(cuid())
  positionId  String
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  duration    Int      @default(30)
  isBooked    Boolean  @default(false)
  candidateId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduledEmail {
  id          String    @id @default(cuid())
  to          String
  subject     String
  type        String
  scheduledAt DateTime
  sentAt      DateTime?
  candidateId String?
  agencyId    String
  status      String    @default("pending")
  metadata    Json?
  createdAt   DateTime  @default(now())
}

// ── HIRE PRODUCT MODELS ──────────────────────────────────────────────
// All Hire models are prefixed with Hire to avoid collision with Interviews models

model HireTenant {
  id          String         @id @default(cuid())
  name        String
  type        HireTenantType
  plan        HirePlan       @default(STARTER)
  domain      String?        @unique
  logoUrl     String?

  // Trial
  trialEndsAt DateTime?
  trialActive Boolean        @default(true)

  // Cashfree billing
  cashfreeCustomerId   String?
  cashfreeSubId        String?
  subscriptionStatus   String?
  usageCandidatesThisMonth Int      @default(0)
  usageResetAt             DateTime?
  currentPeriodEnd         DateTime?
  gettingStarted           Json?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  users           HireUser[]
  jobs            HireJob[]
  candidates      HireCandidate[]
  clients         HireClient[]
  deals           HireDeal[]
  campaigns       HireCampaign[]
  emailTemplates  HireEmailTemplate[]
  apiKeys         ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  jobBoardConnectors JobBoardConnector[]
}

// ── Public API + outbound webhooks (Build 0) ───────────────────────────────
// Foundation for the standalone Interviews product and the Chrome extension.
model ApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      HireTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String                 // human label e.g. "Bullhorn prod"
  prefix      String                 // first chars, shown in UI (e.g. "lvl1_ab12")
  hashedKey   String   @unique       // sha256 hash only — never the raw key
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  @@index([tenantId])
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      HireTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url         String
  secret      String                 // for HMAC-SHA256 signature
  events      String[]               // e.g. ["interview.completed","report.ready"]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([tenantId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  endpointId  String
  event       String
  payload     Json
  status      String   @default("pending")  // pending | success | failed
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  @@index([endpointId])
}

enum HireTenantType {
  AGENCY
  CORPORATE
}

enum HirePlan {
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

model HireUser {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       HireTenant @relation(fields: [tenantId], references: [id])
  email        String
  name         String
  passwordHash String?
  role         HireRole   @default(RECRUITER)
  avatarUrl    String?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum HireRole {
  ADMIN
  RECRUITER
  VIEWER
}

model HireJob {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      HireTenant    @relation(fields: [tenantId], references: [id])
  title       String
  description String        @db.Text
  department  String?
  location    String?
  salaryMin   Int?
  salaryMax   Int?
  stages      Json          // string[] — custom pipeline stages per job
  status      HireJobStatus @default(ACTIVE)
  aiAutoAdvance        Boolean @default(false)
  aiAutoAdvanceThreshold Int   @default(75)
  aiAutoAdvanceStage   String?
  // AI job-brief generator (P0-1) — structured fields that power matching + scoring.
  mustHaveSkills       String[]
  niceToHaveSkills     String[]
  screeningCriteria    String[]
  interviewFocus       String[]
  aiGenerated          Boolean @default(false)
  // Recruiter-defined weighted screening rubric — the canonical thing AI scores
  // candidates against. Json array of { skill, weight (1-5), required (bool) }.
  // Empty/null → scoring falls back to mustHave/niceToHave + description.
  rubric               Json?
  // In-built AI interview question approval: "single" = one authorized user
  // approves both gates; "dual" = tech-lead + HR both approve. Default single.
  approvalMode         String  @default("single")
  autoEmailStage       String?
  autoEmailSubject     String?
  autoEmailBody        String?  @db.Text
  applySlug   String        @unique @default(cuid())
  clientId    String?
  client      HireClient?   @relation(fields: [clientId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  candidates  HireCandidate[]
  postings    JobPosting[]

  @@index([tenantId])
}

// ── AI candidate ↔ job matching (P0-3) ─────────────────────────────────────
// Cached fit results so ranked matches load instantly and only recompute on
// refresh / when the pool changes.
model HireMatch {
  id            String   @id @default(cuid())
  tenantId      String
  jobId         String
  candidateId   String
  score         Int      // 0-100 fit
  verdict       String   // strong | good | partial | weak
  reasons       Json     // string[] — why they fit / gaps
  matchedSkills String[]
  missingSkills String[]
  createdAt     DateTime @default(now())
  @@unique([jobId, candidateId])
  @@index([tenantId, jobId])
  @@index([tenantId, candidateId])
}

// ── Multi-board job distribution (Build 1) ─────────────────────────────────
model JobBoardConnector {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      HireTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  board       String                 // "linkedin" | "indeed" | "naukri" | ...
  mode        String   @default("assisted") // "api" | "assisted"
  credentials Json?                  // encrypted per-tenant creds when in api mode
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@unique([tenantId, board])
}

model JobPosting {
  id          String   @id @default(cuid())
  hireJobId   String
  hireJob     HireJob  @relation(fields: [hireJobId], references: [id], onDelete: Cascade)
  board       String
  status      String   @default("pending") // pending | posted | manual_pending | failed | expired
  externalId  String?                // board's post id when available
  externalUrl String?
  postedAt    DateTime?
  error       String?
  createdAt   DateTime @default(now())
  @@index([hireJobId])
}

enum HireJobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

model HireCandidate {
  id               String     @id @default(cuid())
  tenantId         String
  tenant           HireTenant @relation(fields: [tenantId], references: [id])
  jobId            String?
  job              HireJob?   @relation(fields: [jobId], references: [id])
  name             String
  email            String?    // may be null — a sourced candidate may not have an email yet
  phone            String?
  currentTitle     String?
  currentCompany   String?
  linkedinUrl      String?
  totalYears       Int?
  resumeUrl        String?
  resumeText       String?    @db.Text
  skills           Json?      // string[] — full skills list from résumé extraction
  topSkills        Json?      // string[] — the most job-relevant skills surfaced by AI scoring
  currentStage     String     @default("Sourced")
  aiScore          Int?       // 0-100
  aiSummary        String?    @db.Text
  aiRecommendation String?    // strong_yes | yes | maybe | no
  interviewScore   Int?       // synced from Interviews product
  source           String?    // LinkedIn, Naukri, Referral, Direct
  emailOptOut      Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  activities     HireCandidateActivity[]
  hireInterviews HireInterview[]
  enrichment     CandidateEnrichment?

  @@index([tenantId])
  @@index([tenantId, jobId])
}

// ── Candidate enrichment (Build 3) — role-agnostic, public sources only ────
model CandidateEnrichment {
  id              String   @id @default(cuid())
  hireCandidateId String   @unique
  hireCandidate   HireCandidate @relation(fields: [hireCandidateId], references: [id], onDelete: Cascade)
  roleFamily      String?  // inferred, for UI emphasis only (never gates providers)
  profile         Json?    // normalized: title, employer, yearsExp, location, skills[], education[], certifications[]
  company         Json?    // current employer public context
  github          Json?    // engineering signal when present
  links           Json?    // { linkedin, website, portfolio, twitter, github, ... }
  summary         String?  @db.Text // neutral AI-written summary, labeled AI-generated
  status          String   @default("pending") // pending | enriched | partial | failed
  sources         String[] // which providers contributed, for transparency
  enrichedAt      DateTime?
  createdAt       DateTime @default(now())
}

model HireCandidateActivity {
  id          String        @id @default(cuid())
  candidateId String
  candidate   HireCandidate @relation(fields: [candidateId], references: [id])
  type        String        // stage_change | note | email_sent | interview_scheduled | ai_scored
  note        String?       @db.Text
  fromStage   String?
  toStage     String?
  userId      String?
  createdAt   DateTime      @default(now())
}

model HireClient {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    HireTenant @relation(fields: [tenantId], references: [id])
  name      String
  industry  String?
  website   String?
  logoUrl   String?
  createdAt DateTime   @default(now())

  contacts  HireContact[]
  deals     HireDeal[]
  jobs      HireJob[]

  @@index([tenantId])
}

model HireContact {
  id              String     @id @default(cuid())
  clientId        String
  client          HireClient @relation(fields: [clientId], references: [id])
  name            String
  email           String?
  phone           String?
  role            String?
  linkedinUrl     String?
  lastContactedAt DateTime?
  emailOptOut     Boolean    @default(false)
  createdAt       DateTime   @default(now())

  activities      HireContactActivity[]
}

model HireContactActivity {
  id        String      @id @default(cuid())
  contactId String
  contact   HireContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String      // call | email | meeting | note
  note      String?     @db.Text
  userId    String?
  createdAt DateTime    @default(now())

  @@index([contactId])
}

model HireDeal {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      HireTenant @relation(fields: [tenantId], references: [id])
  clientId    String
  client      HireClient @relation(fields: [clientId], references: [id])
  title       String
  value       Float
  stage       String     @default("Discovery")
  probability Int        @default(10)
  closedAt    DateTime?
  notes       String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
}

model HireInterview {
  id           String              @id @default(cuid())
  candidateId  String
  candidate    HireCandidate       @relation(fields: [candidateId], references: [id])
  scheduledAt  DateTime
  durationMins Int                 @default(45)
  interviewers Json                // string[] — user IDs or names
  type         String              @default("Technical")
  status       HireInterviewStatus @default(SCHEDULED)
  meetLink     String?
  scorecard    Json?
  notes        String?             @db.Text
  remindersSent Json?              // { "24hr": true, "1hr": false }
  createdAt    DateTime            @default(now())
}

enum HireInterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// Integration join — links Hire candidate to Levl1 Interviews session
model HireCampaign {
  id          String               @id @default(cuid())
  tenantId    String
  tenant      HireTenant           @relation(fields: [tenantId], references: [id])
  name        String
  subject     String
  body        String               @db.Text
  status      HireCampaignStatus   @default(DRAFT)
  sentCount   Int                  @default(0)
  openCount   Int                  @default(0)
  failedCount Int                  @default(0)
  recipientCount Int               @default(0)
  audienceType   String            @default("candidates") // candidates | contacts
  audienceFilter Json?             // { stage?, jobId?, source?, clientId? }
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime             @default(now())

  recipients  HireCampaignRecipient[]

  @@index([tenantId])
}

// Reusable 1:1 email templates (Settings → Email Templates). Personalization
// tokens {{name}} {{job}} {{company}} are filled at send time from the
// candidate + job. The 1:1 bridge before full email integration.
model HireEmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    HireTenant @relation(fields: [tenantId], references: [id])
  name      String
  subject   String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model HireCampaignRecipient {
  id         String       @id @default(cuid())
  campaignId String
  campaign   HireCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  status     String       @default("pending") // pending | sent | failed | opened
  sentAt     DateTime?
  openedAt   DateTime?

  @@index([campaignId])
}

enum HireCampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  product   String   // upword
  name      String?
  email     String
  createdAt DateTime @default(now())
}

model HireBillingEvent {
  id        String   @id @default(cuid())
  tenantId  String
  orderId   String   @unique
  planId    String
  amount    Int      // paise
  status    String   // success | failed
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  role      String?
  teamSize  String?
  message   String?  @db.Text
  createdAt DateTime @default(now())
}
