generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  website     String?
  voiceAccent String   @default("american")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // plan: trial | starter | professional | enterprise | expired
  plan              String    @default("trial")
  trialStartedAt    DateTime  @default(now())
  trialExpiresAt    DateTime?
  trialInterviews   Int       @default(0)
  trialLimit        Int       @default(5)

  // Paid subscription
  subscriptionId     String?
  subscriptionStatus String?
  currentPeriodEnd   DateTime?

  // Usage
  interviewsUsed  Int @default(0)
  interviewsLimit Int @default(5)

  // Billing
  billingEmail       String?
  cashfreeCustomerId String?

  // Email / sender config
  senderName           String?
  senderEmail          String?
  resendDomainVerified Boolean @default(false)

  // White-label
  logoUrl    String?
  brandColor String? @default("#4F46E5")

  // Business / GST details
  legalName      String?
  gstNumber      String?
  panNumber      String?
  foundedYear    Int?
  teamSize       String?
  primaryService String?

  // Registered address
  registeredAddress String?
  city              String?
  state             String?
  pinCode           String?

  // Onboarding
  onboardingComplete Boolean @default(false)
  onboardingStep     Int     @default(1)

  positions     Position[]
  users         User[]
  subscriptions Subscription[]
  notifications Notification[]
  teamMembers   TeamMember[]
  clients       Client[]
}

model TeamMember {
  id          String    @id @default(cuid())
  agencyId    String
  agency      Agency    @relation(fields: [agencyId], references: [id])
  name        String
  email       String
  role        String    @default("recruiter") // admin | recruiter | viewer
  status      String    @default("invited")   // invited | active
  inviteToken String?   @unique
  joinedAt    DateTime?
  createdAt   DateTime  @default(now())
}

model Client {
  id           String     @id @default(cuid())
  agencyId     String
  agency       Agency     @relation(fields: [agencyId], references: [id])
  name         String
  industry     String?
  website      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  managerEmail String?
  l2Threshold  Int        @default(75)
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  positions    Position[]
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  phone              String?
  role               String    @default("recruiter")
  agencyId           String
  agency             Agency    @relation(fields: [agencyId], references: [id])
  passwordHash       String?
  emailVerified      Boolean   @default(false)
  emailVerifyToken   String?
  resetPasswordToken String?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  agencyId           String
  agency             Agency    @relation(fields: [agencyId], references: [id])
  plan               String
  status             String
  cashfreeSubId      String?
  amount             Int
  currency           String    @default("INR")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
}

model Position {
  id                 String    @id @default(cuid())
  title              String
  company            String
  department         String?
  roleType           String    @default("IC")
  experienceLevel    String
  primaryDomain      String?
  techStack          String[]
  goodToHave         String[]
  domainContext      String?
  companyStage       String?
  workMode           String    @default("hybrid")
  interviewDuration  Int       @default(30)
  status             String    @default("draft")
  jdText             String?   @db.Text
  jdSource           String?   // pasted | generated | uploaded
  jdApprovedBy       String?
  jdApprovedAt       DateTime?
  techLeadApproved   Boolean   @default(false)
  hrApproved         Boolean   @default(false)
  techLeadEmail      String?
  hrEmail            String?
  clientManagerEmail String?
  l2ScoreThreshold   Int       @default(75)
  rubricApproved     Boolean   @default(false)
  scoringRubric      Json?
  dynamicIntensity   String    @default("standard")
  voiceAccent        String?
  softSkillWeightage Json?
  agencyId           String?
  agency             Agency?   @relation(fields: [agencyId], references: [id])
  clientId           String?
  client             Client?   @relation(fields: [clientId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  candidates     Candidate[]
  questionSet    QuestionSet?
  interviews     Interview[]
  positionReport PositionReport?
  interviewSlots InterviewSlot[]
  approvalTokens ApprovalToken[]
}

model ApprovalToken {
  id         String    @id @default(cuid())
  token      String    @unique @default(uuid())
  positionId String
  position   Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  type       String    // tech_lead | hr | client_jd | client_rubric
  email      String
  name       String?
  status     String    @default("pending") // pending | approved | changes_requested
  comments   String?
  approvedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
}

model QuestionSet {
  id                  String   @id @default(cuid())
  positionId          String   @unique
  position            Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  technicalQuestions  Json
  scenarioQuestions   Json
  behavioralQuestions Json
  eqQuestions         Json
  whiteboardQuestions Json
  timeAllocation      Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Candidate {
  id               String    @id @default(cuid())
  name             String
  email            String
  phone            String?
  linkedIn         String?
  currentTitle     String?
  currentCompany   String?
  totalYears       Int?
  topSkills        String[]
  educationSummary String?
  resumeText       String?   @db.Text
  positionId       String
  position         Position  @relation(fields: [positionId], references: [id])
  status           String    @default("pending")
  invitedAt        DateTime?
  scheduledAt      DateTime?
  interviewedAt    DateTime?
  score            Int?
  recommendation   String?
  uploadedAt       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  interview Interview?
  report    Report?
}

model Interview {
  id                String    @id @default(cuid())
  candidateId       String    @unique
  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  positionId        String
  position          Position  @relation(fields: [positionId], references: [id])
  status            String    @default("scheduled")
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int       @default(30)
  actualDuration    Int?
  agentOnline       Boolean   @default(false)
  candidateJoined   Boolean   @default(false)
  transcript        Json?
  questionResponses Json?
  codeEditorContent String?   @db.Text
  whiteboardUrl     String?
  runningScore      Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  token InterviewToken?
}

model InterviewToken {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Report {
  id                     String    @id @default(cuid())
  candidateId            String    @unique
  candidate              Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  overallScore           Int
  recommendation         String
  professionalSummary    String    @db.Text
  sectionScores          Json
  strengthAreas          Json
  concernAreas           Json
  questionWiseEvaluation Json
  transcriptHighlights   Json
  hrNote                 String    @db.Text
  l2Recommendation       String    @db.Text
  generatedAt            DateTime  @default(now())
}

model PositionReport {
  id                   String   @id @default(cuid())
  positionId           String   @unique
  position             Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  poolStrengths        Json
  poolGaps             Json
  marketObservation    String   @db.Text
  questionHealthFlags  Json
  hiringRecommendation String   @db.Text
  generatedAt          DateTime @default(now())
}

model DeletionLog {
  id         String   @id @default(cuid())
  entityType String   // candidate | interview | position
  entityId   String
  entityName String
  deletedBy  String
  reason     String   @db.Text
  agencyId   String
  createdAt  DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  page      String
  userId    String?
  createdAt DateTime @default(now())
}

model SupportTicket {
  id           String   @id @default(cuid())
  ticketNumber Int      @default(autoincrement())
  issueType    String
  subject      String
  description  String   @db.Text
  userEmail    String
  status       String   @default("open")
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model InterviewSlot {
  id          String   @id @default(cuid())
  positionId  String
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  duration    Int      @default(30)
  isBooked    Boolean  @default(false)
  candidateId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduledEmail {
  id          String    @id @default(cuid())
  to          String
  subject     String
  type        String
  scheduledAt DateTime
  sentAt      DateTime?
  candidateId String?
  agencyId    String
  status      String    @default("pending")
  metadata    Json?
  createdAt   DateTime  @default(now())
}
